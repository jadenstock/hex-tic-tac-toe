{
  "name": "hex-ttt-infra",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "tsc",
    "synth": "cdk synth",
    "deploy": "bash scripts/deploy-hex-ttt.sh",
    "deploy:raw": "cdk deploy --require-approval never",
    "deploy:cert": "cdk deploy HexTttCertificateStack --require-approval never -c domainName=${DOMAIN_NAME:-he-xo.com} -c hostedZoneDomain=${HOSTED_ZONE_DOMAIN:-he-xo.com} -c includeWww=${INCLUDE_WWW:-true}",
    "destroy": "cdk destroy"
  },
  "devDependencies": {
    "@types/node": "^24.12.0",
    "aws-cdk": "^2.1028.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "aws-cdk-lib": "^2.230.0",
    "constructs": "^10.4.2"
  }
}
