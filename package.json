{
  "name": "app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "data:hexo:archive": "node --experimental-strip-types scripts/hexo-archive/fetch-archive-metadata.ts",
    "data:hexo:metadata": "node --experimental-strip-types scripts/hexo-archive/build-clean-metadata.ts",
    "data:hexo:endgames": "node --experimental-strip-types scripts/hexo-archive/classify-replay-endgames.ts",
    "data:hexo:forced-bot-eval": "node --experimental-strip-types scripts/hexo-archive/evaluate-forced-win-bot-turns.ts",
    "data:hexo:replays": "node --experimental-strip-types scripts/hexo-archive/export-replay-subset.ts",
    "bot:opt": "node --experimental-strip-types bot-optimizer/run.ts",
    "bot:opt:gen": "node --experimental-strip-types bot-optimizer/generate-challengers.ts",
    "bot:opt:promote": "node --experimental-strip-types bot-optimizer/promote-best.ts",
    "bot:api": "node --experimental-strip-types bot-api/server.ts",
    "bot:wasm:build": "bash -lc 'source \"$HOME/.cargo/env\" && wasm-pack build wasm-bot --target web --out-dir ../public/wasm-bot --out-name hex_ttt_wasm'",
    "infra:install": "npm --prefix infra install",
    "infra:build": "npm --prefix infra run build",
    "infra:synth": "npm --prefix infra run synth",
    "infra:deploy": "npm --prefix infra run deploy"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1"
  }
}
