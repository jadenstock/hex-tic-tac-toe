# Set this from CDK output: WebSocketUrl
VITE_WS_URL=wss://your-api-id.execute-api.us-east-1.amazonaws.com/prod
# Set this from CDK output: TrackedGamesApiUrl
# In local dev, Vite proxies /api to this target to avoid CORS issues.
# In production builds, the app can also use this value directly if needed.
VITE_API_URL=https://your-api-id.execute-api.us-east-1.amazonaws.com
